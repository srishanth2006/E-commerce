# Copy this file to .env and fill in real values for your environment.
# In production (Railway/Render) set these as dashboard environment
# variables instead of committing a .env file.

# ---- Database ----
# EITHER provide a single DATABASE_URL (Railway/Render usually inject this
# automatically when you attach a MySQL plugin)...
DATABASE_URL=mysql+pymysql://user:password@host:3306/sri_provision_store

# ...OR provide the individual parts (used only if DATABASE_URL is unset):
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=sri_provision_store
# Railway/Render sometimes expose these names instead - also supported:
# MYSQL_HOST=
# MYSQL_PORT=
# MYSQL_USER=
# MYSQL_PASSWORD=
# MYSQL_DATABASE=

# ---- JWT ----
JWT_SECRET=change_this_to_a_long_random_secret_string
SECRET_KEY=change_this_to_a_long_random_secret_string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120

# ---- CORS ----
# The deployed frontend URL(s), comma-separated if more than one.
FRONTEND_ORIGIN=https://your-app.vercel.app
CORS_ORIGINS=https://your-app.vercel.app,http://localhost:5173

# ---- Email / SMTP (Module 1: verification + password reset emails) ----
# Leave SMTP_HOST blank to just print emails to the backend console instead
# of sending them - perfect for local development, no mail account needed.
# Example for Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, and use an
# "App Password" (not your normal Gmail password) for SMTP_PASSWORD.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=no-reply@sriprovision.local

# How long verification/reset links stay valid
RESET_TOKEN_EXPIRE_MINUTES=30
VERIFICATION_TOKEN_EXPIRE_HOURS=24

# Dev convenience ONLY: when true, /auth/forgot-password and
# /auth/resend-verification echo the raw token back in the API response,
# so you can test the flow without SMTP configured. ALWAYS set this to
# False before deploying anywhere real - it defeats email verification.
DEV_EXPOSE_TOKENS=True

# ---- Optional: future AI / OCR integrations (later modules) ----
# OLLAMA_URL=http://localhost:11434
# OCR_ENGINE=tesseract
# TESSERACT_PATH=/usr/bin/tesseract

# ---- Optional: Module 13 AI Chatbot (Ollama passthrough) ----
# Leave blank to use only the built-in rule-based chatbot responses.
# OLLAMA_URL=http://localhost:11434

# ---- Optional: Module 16 Razorpay payments ----
# Get test keys from https://dashboard.razorpay.com/app/keys
# RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
# RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxx
